{
  "expo": {
    "name": "Slide Puzzle",
    "slug": "slidepuzzle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mike008.slidepuzzle"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.mike008.slidepuzzle"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Slide Puzzle to access your photos to set puzzle images.",
          "cameraPermission": "Allow Slide Puzzle to use your camera to take puzzle photos."
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/6e9cf9b7-1358-4145-b09c-cf7c1a694f9c"
    },
    "runtimeVersion": "1.0.0",
    "extra": {
      "eas": {
        "projectId": "6e9cf9b7-1358-4145-b09c-cf7c1a694f9c"
      }
    },
    "owner": "mike008"
  }
}
